rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAdmin() {
      return request.auth.token.role in ['admin', 'superadmin'];
    }
    
    function isSuperAdmin() {
      return request.auth.token.role == 'superadmin';
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    // Public collections - readable by all
    match /products/{document=**} {
      allow read: if true; // Anyone can browse products
      allow write: if isAdmin(); // Only admins can create/update products
      allow delete: if isSuperAdmin(); // Only superadmin can delete
    }
    
    match /reviews/{document=**} {
      allow read: if true; // Public reviews
      allow create: if isAuthenticated(); // Authenticated users can post reviews
      allow update, delete: if isOwner(resource.data.uid);
    }
    
    // Guest & User carts
    match /carts/{sessionId} {
      allow read, write: if request.auth.uid == sessionId || 
                            (request.auth == null && sessionId == request.headers['X-Session-ID']);
    }
    
    // Customer orders
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.uid) || 
                     (resource.data.guestEmail == request.auth.token.email && request.auth != null) ||
                     isAdmin();
      allow create: if true; // Anyone can create orders (validated in Cloud Function)
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }
    
    // Customer profiles
    match /customers/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
      allow read: if isAdmin();
    }
    
    // Coupons
    match /coupons/{document=**} {
      allow read: if request.auth == null || isAuthenticated(); // Everyone can see active coupons
      allow write: if isAdmin();
      allow delete: if isSuperAdmin();
    }
    
    // Coupon usage tracking
    match /coupon_usage/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Admin staff
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }
    
    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
